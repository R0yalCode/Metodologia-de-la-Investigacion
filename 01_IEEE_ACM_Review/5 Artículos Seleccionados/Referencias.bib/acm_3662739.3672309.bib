doi = {10.1145/3662739.3672309},
abstract = {Traditional methods often design training plans based on universal models or averaged data, which cannot fully consider the individual differences and needs of each athlete. This may result in training plans that are not targeted enough to maximize the potential of each athlete. This article uses VAE (Variational Auto-Encoder) to automatically learn the feature representation of athlete data. Based on the characteristics and needs of each athlete, a specialized training plan is designed to maximize their training effectiveness and performance. This article collects a large amount of athlete training data, preprocesses the collected athlete training data, outputs latent representations of features through VAE, and decodes the latent representations into reconstructed data. This article designs a personalized sports training system using athlete features extracted by VAE, providing real-time feedback and guidance. The experiment compared VAE with GAN (Generative Adversarial Networks) and AE (Auto Encoder), and the results showed that the average reconstruction error of VAE was 0.009. The average scores of athletes in basketball games under the three feature extraction methods of VAE, GAN, and AE are 17 points, 13 points, and 11 points, respectively. And athletes are most satisfied with the targeted training program constructed by VAE. Therefore, using VAE can accurately extract athlete features and achieve personalized sports training.},
booktitle = {Proceedings of the 2024 International Conference on Machine Intelligence and Digital Applications},
pages = {574–580},
numpages = {7},
keywords = {Athlete feature extraction, Personalized training scheme, Physical training, Variational auto-encoder},
location = {Ningbo, China},
series = {MIDA '24}
}